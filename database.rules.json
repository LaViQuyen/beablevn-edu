{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('parentLinks').child(auth.uid).child($uid).val() === true)",
        ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
        "password": { ".validate": false }
      }
    },

    "parentLinks": {
      ".read": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
      ".write": "auth != null && auth.token.role === 'admin'",
      "$puid": {
        ".read": "auth != null && auth.uid === $puid"
      }
    },

    "appointments": {
      ".read": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
      "$puid": {
        ".read": "auth != null && auth.uid === $puid",
        "$aid": {
          ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin' || (auth.uid === $puid && auth.token.role === 'parent'))",
          ".validate": "auth.token.role === 'staff' || auth.token.role === 'admin' || (newData.child('parentId').val() === $puid && (newData.child('status').val() === 'cancelled' || (data.exists() && newData.child('status').val() === data.child('status').val()) || (!data.exists() && newData.child('status').val() === 'pending')))",
          "handledBy": { ".validate": "auth.token.role === 'staff' || auth.token.role === 'admin'" },
          "handledAt": { ".validate": "auth.token.role === 'staff' || auth.token.role === 'admin'" },
          "staffNote": { ".validate": "auth.token.role === 'staff' || auth.token.role === 'admin'" }
        }
      }
    },

    "usersPublic": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "userAuth": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.role === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || auth.token.role === 'admin')",
        "password": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "$other": { ".validate": false }
      }
    },

    "coachConfig": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.role === 'admin'"
    },

    "coachUsage": {
      ".read": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    },

    "coachHistory": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.role === 'staff' || auth.token.role === 'admin')"
      }
    },

    "scores": {
      ".read": "auth != null",
      "$cid": {
        "$sid": {
          ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
          "bonus": {
            "$rid": {
              ".write": "auth != null && auth.uid === $sid && auth.token.role === 'student' && !data.exists() && newData.child('score').isNumber() && newData.child('score').val() <= 0",
              "score": { ".validate": "newData.isNumber() || newData.isString()" }
            }
          }
        }
      }
    },

    "staffBonus": {
      ".read": "auth != null && auth.token.role !== 'parent'",
      "$uid": {
        "$rid": {
          ".write": "auth != null && !data.exists() && ( (auth.uid === $uid && (auth.token.role === 'staff' || auth.token.role === 'admin') && newData.child('score').isNumber() && newData.child('score').val() <= 0) || ((auth.token.role === 'admin' || auth.token.bod === true || auth.token.mod === true) && $uid !== auth.uid) )",
          "score": { ".validate": "newData.isNumber() || newData.isString()" }
        }
      }
    },

    "attendance": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "classes": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "bonusRules": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.role === 'admin'"
    },

    "skins": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "ffMenu": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "gifts": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "creditPlus": {
      ".read": "auth != null && auth.token.role !== 'parent'",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "staffCredits": {
      ".read": "auth != null && auth.token.role !== 'parent'",
      ".write": "auth != null && (auth.token.role === 'admin' || auth.token.bod === true)"
    },

    "redemptions": {
      ".read": "auth != null && auth.token.role !== 'parent'",
      "$rid": {
        ".write": "auth != null && (((auth.token.role === 'staff' || auth.token.role === 'admin')) || (!data.exists() && newData.child('studentId').val() === auth.uid) || (data.child('studentId').val() === auth.uid))"
      }
    },

    "messages": {
      ".read": "auth != null && auth.token.role !== 'parent'",
      ".write": "auth != null && auth.token.role !== 'parent'"
    },

    "feedback": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "notifications_files": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "staffNotifications": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "fcmTokens": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.role === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || auth.token.role === 'admin')"
      }
    },

    "classReminders": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.role === 'admin'"
    },

    "studentSkins": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || auth.token.role === 'staff' || auth.token.role === 'admin')"
      }
    },

    "studentGames": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
        "hanhTrinh": {
          "totalStars": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && (auth.token.role === 'admin' || auth.token.role === 'staff' || (data.exists() ? (newData.val() >= data.val() && newData.val() <= data.val() + 5000) : newData.val() <= 5000))"
          },
          "playsUsed": {
            ".write": "auth != null && (auth.uid === $uid || auth.token.role === 'staff' || auth.token.role === 'admin')",
            ".validate": "newData.isNumber() && newData.val() >= 0 && (auth.token.role === 'admin' || auth.token.role === 'staff' || !data.exists() || newData.val() >= data.val())"
          },
          "unlockedSkills": { ".validate": "newData.isBoolean()" },
          "rank":           { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5" },
          "updatedAt":      { ".validate": "newData.isString() && newData.val().length <= 40" },
          "beaten": {
            "$k": { ".validate": "newData.isBoolean() && $k.matches(/^([0-9]|1[0-9]|2[0-4])$/)" }
          },
          "playLog": {
            "$d": {
              ".write": "auth != null && (auth.uid === $uid || auth.token.role === 'staff' || auth.token.role === 'admin')",
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 500 && (auth.token.role === 'admin' || auth.token.role === 'staff' || !data.exists() || newData.val() >= data.val())"
            }
          },
          "$other": { ".validate": false }
        }
      }
    },

    "tuitionRecords": {
      ".read": "auth != null && auth.token.role === 'admin'",
      ".write": "auth != null && auth.token.role === 'admin'",
      "$code": {
        ".read": "auth != null && (auth.token.role === 'admin' || root.child('users').child(auth.uid).child('studentCode').val() === $code)",
        "$id": {
          "extensionRequested":   { ".write": "auth != null && (auth.token.role === 'admin' || (auth.token.role === 'student' && root.child('users').child(auth.uid).child('studentCode').val() === $code && root.child('tuitionRecords').child($code).child($id).child('status').val() === 'Chờ'))", ".validate": "newData.isBoolean()" },
          "extensionRequestedAt": { ".write": "auth != null && (auth.token.role === 'admin' || (auth.token.role === 'student' && root.child('users').child(auth.uid).child('studentCode').val() === $code && root.child('tuitionRecords').child($code).child($id).child('status').val() === 'Chờ'))", ".validate": "newData.isString() && newData.val().length <= 40" },
          "extensionApproved":    { ".write": "auth != null && (auth.token.role === 'admin' || (auth.token.role === 'student' && root.child('users').child(auth.uid).child('studentCode').val() === $code && root.child('tuitionRecords').child($code).child($id).child('status').val() === 'Chờ' && newData.val() === false))", ".validate": "newData.isBoolean()" },
          "status":               { ".write": "auth != null && (auth.token.role === 'admin' || (auth.token.role === 'student' && root.child('users').child(auth.uid).child('studentCode').val() === $code && root.child('tuitionRecords').child($code).child($id).child('status').val() === 'Chờ' && newData.val() === 'Chờ duyệt gia hạn'))" }
        }
      }
    },

    "tuitionSnapshots": {
      ".read": "auth != null && auth.token.role === 'admin'",
      ".write": "auth != null && auth.token.role === 'admin'"
    },

    "tuitionDeductions": {
      ".read": "auth != null && auth.token.role === 'admin'",
      ".write": false
    }
  }
}
