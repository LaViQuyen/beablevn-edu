{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
        "password": {
          ".write": "auth != null && (auth.token.role === 'admin' || auth.token.role === 'staff' || auth.uid === $uid)"
        }
      }
    },

    "coachConfig": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.role === 'admin'"
    },

    "coachUsage": {
      ".read": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    },

    "coachHistory": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.role === 'staff' || auth.token.role === 'admin')"
      }
    },

    "scores": {
      ".read": "auth != null",
      "$cid": {
        "$sid": {
          ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
          "bonus": {
            "$rid": {
              ".write": "auth != null && auth.uid === $sid && auth.token.role === 'student' && !data.exists() && newData.child('score').isNumber() && newData.child('score').val() <= 0",
              "score": { ".validate": "newData.isNumber() || newData.isString()" }
            }
          }
        }
      }
    },

    "staffBonus": {
      ".read": "auth != null",
      "$uid": {
        "$rid": {
          ".write": "auth != null && !data.exists() && ( (auth.uid === $uid && (auth.token.role === 'staff' || auth.token.role === 'admin') && newData.child('score').isNumber() && newData.child('score').val() <= 0) || ((auth.token.role === 'admin' || auth.token.bod === true || auth.token.mod === true) && $uid !== auth.uid) )",
          "score": { ".validate": "newData.isNumber() || newData.isString()" }
        }
      }
    },

    "attendance": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "classes": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "bonusRules": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.role === 'admin'"
    },

    "skins": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "ffMenu": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "gifts": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "creditPlus": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "staffCredits": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'admin' || auth.token.bod === true)"
    },

    "redemptions": {
      ".read": "auth != null",
      "$rid": {
        ".write": "auth != null && (((auth.token.role === 'staff' || auth.token.role === 'admin')) || (!data.exists() && newData.child('studentId').val() === auth.uid) || (data.child('studentId').val() === auth.uid))"
      }
    },

    "messages": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "feedback": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "notifications_files": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')"
    },

    "staffNotifications": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "fcmTokens": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.role === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || auth.token.role === 'admin')"
      }
    },

    "classReminders": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.role === 'admin'"
    },

    "studentSkins": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || auth.token.role === 'staff' || auth.token.role === 'admin')"
      }
    },

    "studentGames": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || auth.token.role === 'staff' || auth.token.role === 'admin')",
        "hanhTrinh": {
          "totalStars": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && (auth.token.role === 'admin' || auth.token.role === 'staff' || (data.exists() ? (newData.val() >= data.val() && newData.val() <= data.val() + 5000) : newData.val() <= 5000))"
          },
          "playsUsed":      { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "unlockedSkills": { ".validate": "newData.isBoolean()" },
          "rank":           { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5" },
          "updatedAt":      { ".validate": "newData.isString() && newData.val().length <= 40" },
          "beaten": {
            "$k": { ".validate": "newData.isBoolean() && $k.matches(/^([0-9]|[12][0-9]|30)$/)" }
          },
          "playLog": {
            "$d": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 500" }
          },
          "$other": { ".validate": false }
        }
      }
    },

    "tuitionRecords": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.role === 'admin'",
      "$id": {
        "extensionRequested":   { ".write": "auth != null && (auth.token.role === 'admin' || (auth.token.role === 'student' && root.child('users').child(auth.uid).child('studentCode').val() === root.child('tuitionRecords').child($id).child('studentCode').val()))", ".validate": "newData.isBoolean()" },
        "extensionRequestedAt": { ".write": "auth != null && (auth.token.role === 'admin' || (auth.token.role === 'student' && root.child('users').child(auth.uid).child('studentCode').val() === root.child('tuitionRecords').child($id).child('studentCode').val()))", ".validate": "newData.isString()" },
        "extensionApproved":    { ".write": "auth != null && (auth.token.role === 'admin' || (auth.token.role === 'student' && root.child('users').child(auth.uid).child('studentCode').val() === root.child('tuitionRecords').child($id).child('studentCode').val() && newData.val() === false))" },
        "status":               { ".write": "auth != null && (auth.token.role === 'admin' || (auth.token.role === 'student' && root.child('users').child(auth.uid).child('studentCode').val() === root.child('tuitionRecords').child($id).child('studentCode').val() && newData.val() === 'Chờ duyệt gia hạn'))" }
      }
    },

    "tuitionSnapshots": {
      ".read": "auth != null && auth.token.role === 'admin'",
      ".write": "auth != null && auth.token.role === 'admin'"
    },

    "playLog": {
      ".read": "auth != null && (auth.token.role === 'staff' || auth.token.role === 'admin')",
      ".write": "auth != null"
    }
  }
}
