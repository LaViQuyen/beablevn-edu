/* ============================================================
   DESIGN TOKENS — Be Able VN / 2Sol EDU
   Thay đổi màu thương hiệu: chỉ cần sửa --color-primary
   ============================================================ */
:root {
  /* === Màu thương hiệu === */
  --color-primary:        #003366;
  --color-primary-hover:  #002244;
  --color-primary-light:  #EEF3FA;   /* bg-blue-50 tương đương */
  --color-primary-ring:   #003366/10;

  /* === Màu trạng thái === */
  --color-success:   #059669;
  --color-warning:   #D97706;
  --color-danger:    #DC2626;
  --color-info:      #2563EB;

  /* === Border radius === */
  --radius-sm:  6px;   /* badge, tag nhỏ */
  --radius-md:  12px;  /* input, button, card — rounded-xl */
  --radius-lg:  16px;  /* modal, drawer     — rounded-2xl */
  --radius-full: 9999px; /* pill, avatar */

  /* === Shadow === */
  --shadow-card:   0 1px 3px 0 rgb(0 0 0 / 0.06), 0 1px 2px -1px rgb(0 0 0 / 0.04);
  --shadow-hover:  0 4px 6px -1px rgb(0 0 0 / 0.08), 0 2px 4px -2px rgb(0 0 0 / 0.05);
  --shadow-modal:  0 20px 50px -10px rgb(0 0 0 / 0.18);

  /* === Transition === */
  --transition-base: 150ms cubic-bezier(0.4, 0, 0.2, 1);
}

/* ============================================================
   BASE STYLES
   ============================================================ */
body {
  font-family: 'Josefin Sans', sans-serif;
  background-color: #f8fafc;
  color: #111827;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

button, input, optgroup, select, textarea {
  font-family: 'Josefin Sans', sans-serif;
}

/* ============================================================
   UTILITY CLASSES — Design System
   Dùng trong JSX: className="btn-primary", "card", "input-base"
   ============================================================ */
@layer components {

  /* --- Buttons --- */
  .btn {
    @apply inline-flex items-center justify-center gap-2 font-bold rounded-xl transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed;
  }
  .btn-sm  { @apply btn px-3 py-2 text-xs; }
  .btn-md  { @apply btn px-5 py-2.5 text-sm; }
  .btn-lg  { @apply btn px-8 py-3 text-sm; }

  .btn-primary  { @apply btn-md bg-[#003366] text-white hover:bg-[#002244] shadow-sm; }
  .btn-secondary{ @apply btn-md bg-slate-100 text-slate-700 hover:bg-slate-200; }
  .btn-danger   { @apply btn-md bg-red-500 text-white hover:bg-red-600; }
  .btn-ghost    { @apply btn-md text-slate-600 hover:bg-slate-100; }
  .btn-outline  { @apply btn-md border border-[#003366] text-[#003366] hover:bg-[#003366] hover:text-white; }

  /* --- Inputs --- */
  .input-base {
    @apply w-full border border-slate-200 p-3 rounded-xl text-sm outline-none
           focus:border-[#003366] focus:ring-2 focus:ring-[#003366]/10
           bg-white transition-all placeholder:text-slate-400;
  }
  .input-error {
    @apply border-red-300 focus:border-red-400 focus:ring-red-100;
  }

  /* --- Cards --- */
  .card {
    @apply bg-white rounded-xl border border-slate-100 shadow-sm;
  }
  .card-hover {
    @apply card hover:shadow-md hover:border-blue-100 transition-all;
  }
  .card-body {
    @apply p-4 md:p-6;
  }

  /* --- Badges / Tags --- */
  .badge {
