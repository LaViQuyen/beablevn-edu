  /* --- Inline alert messages --- */
  .alert-error   { @apply flex items-start gap-2 bg-red-50 text-red-700 border border-red-200 px-4 py-3 rounded-xl text-sm; }
  .alert-success { @apply flex items-center gap-2 bg-green-50 text-green-700 border border-green-200 px-4 py-3 rounded-xl text-sm font-medium; }
  .alert-warning { @apply flex items-start gap-2 bg-amber-50 text-amber-700 border border-amber-200 px-4 py-3 rounded-xl text-sm; }
}

/* ============================================================
