  }
  .badge-blue   { @apply badge bg-blue-50 text-blue-700 border-blue-200; }
  .badge-green  { @apply badge bg-green-50 text-green-700 border-green-200; }
  .badge-amber  { @apply badge bg-amber-50 text-amber-700 border-amber-200; }
  .badge-red    { @apply badge bg-red-50 text-red-700 border-red-200; }
  .badge-purple { @apply badge bg-purple-50 text-purple-700 border-purple-200; }
  .badge-slate  { @apply badge bg-slate-50 text-slate-600 border-slate-200; }

  /* --- Section headers --- */
  .page-header {
    @apply flex items-center gap-3 pb-4 border-b border-slate-100 mb-6;
  }
  .page-header-icon {
    @apply p-2 rounded-lg flex-shrink-0;
  }

  /* --- Form labels --- */
  .label {
    @apply text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1.5;
  }

  /* --- Skeleton pulse --- */
  .skeleton {
    @apply bg-slate-100 rounded-xl animate-pulse;
